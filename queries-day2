======= display total iphones sales in march month=======


select sum(sales.order_qty * sales.order_price) as total_iphone_sales
from products inner join sales
on products.id = sales.product_id
where products.product = 'IPhone' and (sales.order_date BETWEEN '2025-03-01' and '2025-03-31') or (sales.order_date BETWEEN '2026-03-01' and '2026-03-31');




