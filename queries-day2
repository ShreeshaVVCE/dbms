======= discount_percentage depends on 
if purchase_price > 50k -> 10%
if purchase_price <= 50k and > 20k -> 5%
if purchase_price <= 20k -> 1%  =======

===============common table expression=====================


with discount_table as (
	select products.product , stocks.purchase_price,
	case
	when stocks.purchase_price > 50000 then 10
	when stocks.purchase_price <=50000 and stocks.purchase_price > 20000 then 5
	else 1
	end as discount_percentage
	from products inner join stocks
	on products.id = stocks.product_id
)
select product, purchase_price, discount_percentage, 
(purchase_price - (purchase_price * discount_percentage /100)) as price_after_discount
from discount_table;





========= display max purchased product cat name in terms of qty ======
================only product cat name should be displayed=============


with total_stocks as (
select product_cat.product_cat, sum(stocks.purchase_qty) as total
from products inner join product_cat
on products.product_cat_id = product_cat.id
inner join stocks
on stocks.product_id = products.id
group by product_cat.id
)
select product_cat from total_stocks
order by total DESC
limit 1;




